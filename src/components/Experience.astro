---
// ── Add your experience here ───────────────────────────────────────────────
const experiences: {
  company: string;
  role: string;
  period: string;
  location?: string;
  bullets: string[];
  current?: boolean;
}[] = [
  {
    company: 'Ontario Securities Commission',
    role: 'Information Services Intern',
    period: 'May 2024 - August 2024',
    location: 'Toronto, Ontario',
    current: false,
    bullets: [
      'Engineered a scalable, event-driven messaging system using Java, Spring Boot, and Azure Services (Functions, Service Bus) to automate and streamline data processing workflows.',
      'Operated across the full software development lifecycle using a modern tech stack, including Azure DevOps, Postman for API testing, DBeaver for database management, and IDEs like IntelliJ and VS Code.',
    ],
  },
  {
    company: 'City of Toronto',
    role: 'Lifeguard & Swim Instructor',
    period: 'Jun 2022 — Aug 2023',
    location: 'Toronto, Ontario',
    bullets: [
      'Taught swimming lessons to groups of children and adults, tailoring the lessons to the needs of the students.',
      'Ensured the safety of the swimmers by enforcing the rules and regulations of the pool.',
    ],
  },
  {
    company: 'Legislative Assembly of Ontario',
    role: 'Legislative Page',
    period: 'Feb 2019 — March 2019',
    location: 'Toronto, Ontario',
    bullets: [
      'Learned the basics of the legislative process, and how to navigate the legislative assembly of Ontario.',
      'Helped with the daily operations of the legislative assembly of Ontario by traversing the chambers in order to deliver messages or bills to the appropriate parties.',
    ],
  },
];

const currentSchool = {
  name: 'University of Western Ontario',
  program: 'Bachelor of Engineering Science, Software Engineering',
  expectedGraduation: 'Expected Graduation: June 2027',
};
// ────────────────────────────────────────────────────────────────────────────
---

<section id="experience" class="py-24 px-6 border-t border-border">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-14">
      <p class="section-label mb-4">02 — Experience</p>
      <h2 class="section-heading text-3xl sm:text-4xl font-semibold tracking-tight text-text-primary">
        Where I've Worked
      </h2>
    </div>

    <!-- Current education -->
    <div class="mb-10 border border-border bg-surface px-5 py-4">
      <p class="font-mono text-2xs tracking-widest uppercase text-red-guards mb-2">
        Currently attending
      </p>
      <p class="text-base font-semibold text-text-primary">{currentSchool.name}</p>
      <p class="text-sm text-text-secondary mt-1">{currentSchool.program}</p>
      <p class="font-mono text-2xs tracking-wide text-text-muted mt-2">{currentSchool.expectedGraduation}</p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-0 top-1.5 bottom-1.5 w-px bg-border hidden sm:block"></div>

      <ol class="flex flex-col gap-12 sm:pl-10">
        {experiences.map((exp) => (
          <li class="relative">
            <!-- Timeline dot -->
            <div class="absolute -left-11 top-1.5 hidden sm:flex h-2.5 w-2.5 items-center justify-center">
              <div class={`h-2.5 w-2.5 shrink-0 rounded-full border ${exp.current ? 'bg-red-guards border-red-guards' : 'bg-background border-border'}`}></div>
            </div>

            <!-- Content -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
              <div>
                <h3 class="text-base font-semibold text-text-primary">{exp.company}</h3>
                <p class="text-sm text-text-secondary">{exp.role}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="font-mono text-xs text-text-muted tracking-wide">{exp.period}</p>
                {exp.location && (
                  <p class="font-mono text-2xs text-text-muted tracking-wide mt-0.5">{exp.location}</p>
                )}
                {exp.current && (
                  <span class="inline-block mt-1 font-mono text-2xs tracking-widest uppercase text-red-guards border border-red-guards/30 px-1.5 py-0.5 transition-none">
                    Current
                  </span>
                )}
              </div>
            </div>

            <!-- Bullets -->
            <ul class="flex flex-col gap-2">
              {exp.bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-sm text-text-secondary leading-relaxed">
                  <span class="shrink-0 mt-[0.6rem] w-1 h-1 rounded-full bg-red-guards"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
