---
// ── Add your experience here ───────────────────────────────────────────────
const experiences: {
  company: string;
  role: string;
  period: string;
  location?: string;
  bullets: string[];
  current?: boolean;
}[] = [
  {
    company: 'Company Name',
    role: 'Your Role',
    period: 'Jan 2025 — Present',
    location: 'City, Country',
    current: true,
    bullets: [
      'Key responsibility or achievement — replace with your own.',
      'Another impactful contribution to highlight.',
      'One more detail worth mentioning.',
    ],
  },
  {
    company: 'Previous Company',
    role: 'Your Role',
    period: 'Jun 2023 — Dec 2024',
    location: 'City, Country',
    bullets: [
      'Key responsibility or achievement — replace with your own.',
      'Another impactful contribution to highlight.',
    ],
  },
  {
    company: 'Earlier Role',
    role: 'Your Role',
    period: 'Sep 2022 — May 2023',
    bullets: [
      'Key responsibility or achievement — replace with your own.',
    ],
  },
];
// ────────────────────────────────────────────────────────────────────────────
---

<section id="experience" class="py-24 px-6 border-t border-border">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-14">
      <p class="section-label mb-4">02 — Experience</p>
      <h2 class="section-heading text-3xl sm:text-4xl font-semibold tracking-tight text-text-primary">
        Where I've Worked
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-0 top-2 bottom-2 w-px bg-border hidden sm:block"></div>

      <ol class="flex flex-col gap-12 sm:pl-10">
        {experiences.map((exp) => (
          <li class="relative">
            <!-- Timeline dot -->
            <div class="absolute -left-[2.65rem] top-1.5 hidden sm:flex items-center justify-center">
              <div class={`w-2 h-2 rounded-full border ${exp.current ? 'bg-red-guards border-red-guards shadow-[0_0_6px_#B00000]' : 'bg-background border-border'}`}></div>
            </div>

            <!-- Content -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
              <div>
                <h3 class="text-base font-semibold text-text-primary">{exp.company}</h3>
                <p class="text-sm text-text-secondary">{exp.role}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="font-mono text-xs text-text-muted tracking-wide">{exp.period}</p>
                {exp.location && (
                  <p class="font-mono text-2xs text-text-muted tracking-wide mt-0.5">{exp.location}</p>
                )}
                {exp.current && (
                  <span class="inline-block mt-1 font-mono text-2xs tracking-widest uppercase text-red-guards border border-red-guards/30 px-1.5 py-0.5">
                    Current
                  </span>
                )}
              </div>
            </div>

            <!-- Bullets -->
            <ul class="flex flex-col gap-2">
              {exp.bullets.map((bullet) => (
                <li class="flex gap-3 text-sm text-text-secondary leading-relaxed">
                  <span class="shrink-0 mt-2 w-1 h-1 rounded-full bg-red-guards"></span>
                  {bullet}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
