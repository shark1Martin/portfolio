---
// ── Add your club / organization involvement here ─────────────────────────
const clubs: {
  name: string;
  role: string;
  period: string;
  description: string;
  tags?: string[];
}[] = [
  {
    name: 'Western Formula Racing (FSAE)',
    role: 'Data Acquisition Engineer',
    period: '2025-Present',
    description: 'Apart of a team of student engineers who are dedicated to building a race car from scratch. My team focuses on the data acquisition system of the car, which includes sensors and data logging.',
    tags: ['Design', 'Engineering'],
  },
  {
    name: 'Western Pickleball Club',
    role: 'Athlete',
    period: '2025-Present',
    description: 'Attend weekly pickleball sessions with other students and faculty to improve my skills and fitness.',
    tags: ['Fitness', 'Community'],
  },
  {
    name: 'Western Muay Thai Club',
    role: 'Athlete',
    period: '2026-Present',
    description: 'Attend weekly muay thai trainingsessions with other students and faculty to improve my skills and fitness.',
    tags: ['Fitness', 'Community'],
  },
  {
    name: 'Western Student Council',
    role: 'SOPH - Orientation Leader',
    period: '2024-2025',
    description: 'Helped incoming students transition to Western by providing them with information about the university all while providing a fun and engaging experience for them.',
    tags: ['Leadership', 'Community'],
  },
];
// ────────────────────────────────────────────────────────────────────────────
---

<section id="club-work" class="py-24 px-6 border-t border-border">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-14">
      <p class="section-label mb-4">03 — Club Work</p>
      <h2 class="section-heading text-3xl sm:text-4xl font-semibold tracking-tight text-text-primary">
        Organizations
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {clubs.map((club) => (
        <div class="group bg-surface border border-border p-6 hover:border-red-guards/40 transition-all duration-300">
          <!-- Header -->
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="text-sm font-semibold text-text-primary">{club.name}</h3>
              <p class="text-xs text-text-secondary mt-0.5">{club.role}</p>
            </div>
            <span class="font-mono text-2xs tracking-wide text-text-muted shrink-0 mt-0.5">
              {club.period}
            </span>
          </div>

          <!-- Description -->
          <p class="text-xs text-text-secondary leading-relaxed mb-4">{club.description}</p>

          <!-- Tags -->
          {club.tags && club.tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {club.tags.map((tag) => (
                <li>
                  <span class="font-mono text-2xs tracking-wide text-text-muted border border-border px-2 py-0.5">
                    {tag}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
