---
import { getSimpleIconSlug, getSimpleIconSrc } from '../lib/stackIcons';

interface Props {
  tech: string;
  variant?: 'card' | 'modal' | 'page';
}

const { tech, variant = 'card' } = Astro.props;
const slug = getSimpleIconSlug(tech);
const iconSrc = slug ? getSimpleIconSrc(slug) : null;

const size = variant === 'page' ? 16 : 14;

const styles: Record<typeof variant, string> = {
  card: 'font-mono text-2xs tracking-wide text-text-muted bg-surface-2 px-2 py-1',
  modal: 'font-mono text-2xs tracking-wide text-text-muted bg-surface-2 border border-border px-2 py-1',
  page: 'font-mono text-xs tracking-wide text-text-muted bg-surface border border-border px-3 py-1.5',
};
---

<span class:list={['inline-flex items-center gap-1.5', styles[variant]]}>
  {iconSrc && (
    <img
      src={iconSrc}
      alt=""
      width={size}
      height={size}
      class="shrink-0 opacity-95"
      loading="lazy"
      decoding="async"
    />
  )}
  {tech}
</span>
