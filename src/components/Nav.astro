---
const navLinks = [
  { label: 'Projects', href: '#projects' },
  { label: 'Experience', href: '#experience' },
  { label: 'Club Work', href: '#club-work' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-border/80 backdrop-blur-[1.5px]"
  style="background: rgba(13,15,18,0.92);"
>
  <div class="max-w-6xl mx-auto px-6">
    <nav class="h-14 flex items-center justify-between">
      <!-- Wordmark / monogram -->
      <a
        href="#"
        class="font-mono text-sm font-medium tracking-widest text-text-primary hover:text-red-guards transition-colors duration-200 uppercase"
      >
        <!-- Replace with your initials or name -->
        MM
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-mono text-xs tracking-widest uppercase text-text-secondary hover:text-text-primary transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="mobile-nav-toggle"
        type="button"
        class="md:hidden flex flex-col gap-1.5 p-1 group"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <span class="block w-5 h-px bg-text-secondary group-hover:bg-text-primary transition-colors"></span>
        <span class="block w-5 h-px bg-text-secondary group-hover:bg-text-primary transition-colors"></span>
        <span class="block w-3 h-px bg-red-guards"></span>
      </button>
    </nav>

    <div
      id="mobile-nav-panel"
      class="md:hidden hidden border-t border-border/80 py-4"
      role="navigation"
      aria-label="Mobile"
    >
      <ul class="flex flex-col gap-4 items-end">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-mono text-xs tracking-widest uppercase text-text-secondary hover:text-text-primary transition-colors duration-200 py-1 block text-right"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');

  function setMobileNavOpen(open: boolean) {
    if (!panel || !toggle) return;
    panel.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }

  toggle?.addEventListener('click', () => {
    const open = panel?.classList.contains('hidden') ?? true;
    setMobileNavOpen(open);
  });

  panel?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setMobileNavOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.classList.contains('hidden')) {
      setMobileNavOpen(false);
    }
  });
</script>
