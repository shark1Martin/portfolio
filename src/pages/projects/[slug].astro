---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { name, description, stack, status, github, demo, year } = project.data;

const statusConfig = {
  Shipped: { color: 'text-emerald-400 border-emerald-400/30 bg-emerald-400/5' },
  'In Progress': { color: 'text-amber-400 border-amber-400/30 bg-amber-400/5' },
  Concept: { color: 'text-text-muted border-border bg-transparent' },
};

const { color } = statusConfig[status];
---

<Layout title={`${name} — Project`} description={description}>
  <Nav />

  <main class="min-h-screen pt-14">
    <article class="max-w-3xl mx-auto px-6 py-20">

      <!-- Back link -->
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-text-muted hover:text-text-primary transition-colors mb-12 group"
      >
        <svg
          class="group-hover:-translate-x-1 transition-transform"
          xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
        >
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        All Projects
      </a>

      <!-- Project header -->
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`font-mono text-2xs tracking-widest uppercase px-2 py-1 border ${color}`}>
            {status}
          </span>
          {year && (
            <span class="font-mono text-2xs tracking-wide text-text-muted">{year}</span>
          )}
        </div>

        <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-text-primary mb-6">
          {name}
        </h1>

        <p class="text-lg text-text-secondary leading-relaxed mb-8">
          {description}
        </p>

        <!-- Stack -->
        <ul class="flex flex-wrap gap-2 mb-8">
          {stack.map((tech) => (
            <li>
              <span class="font-mono text-xs tracking-wide text-text-muted bg-surface border border-border px-3 py-1.5">
                {tech}
              </span>
            </li>
          ))}
        </ul>

        <!-- Links -->
        {(github || demo) && (
          <div class="flex items-center gap-6">
            {github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-text-secondary hover:text-text-primary transition-colors border border-border px-4 py-2 hover:border-text-muted"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
                GitHub
              </a>
            )}
            {demo && (
              <a
                href={demo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase bg-red-guards text-white px-4 py-2 hover:bg-red-guards-glow transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                </svg>
                Live Demo
              </a>
            )}
          </div>
        )}
      </header>

      <!-- Red divider -->
      <div class="flex items-center gap-4 mb-12">
        <div class="h-px w-16 bg-red-guards"></div>
        <div class="h-px flex-1 bg-border"></div>
      </div>

      <!-- Markdown body -->
      <div class="prose mb-16">
        <Content />
      </div>

      <!-- ── Media section ──────────────────────────────────────────────────
           Replace the placeholder below with your actual images/videos.
           Example image: <img src="/projects/my-app/screenshot.png" alt="..." />
           Example video: <video src="/projects/my-app/demo.mp4" controls />
      ─────────────────────────────────────────────────────────────────────── -->
      <section class="mb-16">
        <p class="section-label mb-6">Media</p>
        <div class="border border-dashed border-border rounded-sm p-12 flex flex-col items-center justify-center gap-3 text-center">
          <svg class="text-text-muted" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <p class="font-mono text-2xs tracking-widest uppercase text-text-muted">Photos &amp; videos coming soon</p>
        </div>
      </section>

      <!-- Bottom nav -->
      <div class="border-t border-border pt-8">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-text-muted hover:text-text-primary transition-colors group"
        >
          <svg
            class="group-hover:-translate-x-1 transition-transform"
            xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
          >
            <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
          </svg>
          Back to All Projects
        </a>
      </div>

    </article>
  </main>
</Layout>
